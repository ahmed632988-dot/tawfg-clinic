<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>خدمات عيادة الاسنان</title>
<style>
* {box-sizing: border-box; margin: 0; padding: 0;}
body {
  font-family: 'Tajawal', Arial, sans-serif;
  background: #f8f9fa;
  color: #333;
}
.page-header {
  background: linear-gradient(135deg, #0d6efd, #0b5ed7);
  color: #fff;
  padding: 60px 20px;
  text-align: center;
}
.page-header h1 {
  font-size: 36px;
  margin-bottom: 10px;
}
.page-header p {
  font-size: 18px;
  opacity: 0.9;
}
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 50px 20px;
}
.services {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 25px;
}
.service-card {
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.08);
  overflow: hidden;
  transition: transform 0.3s;
}
.service-card:hover {
  transform: translateY(-5px);
}
.service-card img {
  width: 100%;
  height: 200px;
  object-fit: cover;
  background: #e9ecef;
}
.service-content {
  padding: 20px;
  text-align: center;
}
.service-content h3 {
  color: #0d6efd;
  margin-bottom: 10px;
  font-size: 22px;
}
.service-content p {
  color: #666;
  margin-bottom: 15px;
  line-height: 1.6;
}
.price {
  font-size: 24px;
  font-weight: 700;
  color: #28a745;
}
.loading {
  text-align: center;
  font-size: 18px;
  color: #666;
  padding: 50px;
}
</style>
</head>
<body>

<div class="page-header">
  <h1 id="page-title">جاري التحميل...</h1>
  <p id="page-subtitle"></p>
</div>

<div class="container">
  <div class="services" id="services-list">
    <div class="loading">جاري تحميل الخدمات...</div>
  </div>
</div>

<script>
fetch('/content/services.json')
.then(res => {
  if (!res.ok) throw new Error('الملف ما لقيتو');
  return res.json();
})
.then(data => {
  document.getElementById('page-title').innerText = data.title;
  document.getElementById('page-subtitle').innerText = data.subtitle;
  
  let html = '';
  data.services.forEach(service => {
    html += `
    <div class="service-card">
      <img src="${service.image}" alt="${service.name}" onerror="this.src='https://via.placeholder.com/400x200'">
      <div class="service-content">
        <h3>${service.name}</h3>
        <p>${service.description}</p>
        <div class="price">${service.price}</div>
      </div>
    </div>
    `;
  });
  document.getElementById('services-list').innerHTML = html;
})
.catch(err => {
  document.getElementById('services-list').innerHTML = 
    '<div class="loading">حصل خطأ في تحميل الخدمات. اتاكد انو ملف services.json موجود</div>';
  console.error(err);
});
</script>

</body>
</html>
